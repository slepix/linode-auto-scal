# Required: Encryption key for Linode tokens, root passwords, and bearer tokens
# Must be at least 32 characters
AUTOSCALER_SECRET_KEY=

# PostgreSQL password (used in Docker Compose)
POSTGRES_PASSWORD=

# Optional overrides
DEBUG=false
POLL_INTERVAL_SECONDS=5
RECONCILE_INTERVAL_SECONDS=60

# For Terraform (Linode API token with account-level permissions)
# TF_VAR_linode_token=
# TF_VAR_ssh_public_key=
